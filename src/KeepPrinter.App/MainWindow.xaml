<Window
    x:Class="KeepPrinter.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                Padding="24,16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="KeepPrinter (Bunker Print Master)" FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="Impresión profesional por tandas con reanudación" 
                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="24" Spacing="24" MaxWidth="800">

                <!-- Estado del Proyecto -->
                <StackPanel Spacing="12">
                    <TextBlock Text="🎉 Estado del Proyecto" FontSize="20" FontWeight="SemiBold"/>
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                            <!-- Fase 0 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Fase 0: Estructura Base" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="✅ Completa" Foreground="Green"/>

                            <!-- Fase 1 -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fase 1: Dominio + Tests (36 tests)" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="✅ Completa" Foreground="Green"/>

                            <!-- Fase 2a -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Fase 2a: PdfService (14 tests)" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="✅ Completa" Foreground="Green"/>

                            <!-- Fase 2b -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Fase 2b: PrintService (12 tests)" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="✅ Completa" Foreground="Green"/>

                            <!-- Siguiente -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Siguiente: SessionStore" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="🔄 Pendiente" Foreground="Orange"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Tests -->
                <StackPanel Spacing="12">
                    <TextBlock Text="🧪 Tests" FontSize="20" FontWeight="SemiBold"/>
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock>
                                <Run Text="Total: " FontWeight="SemiBold"/>
                                <Run Text="62 tests pasando" Foreground="Green" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock Text="• Core: 36 tests ✅" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="• Infrastructure (PdfService): 14 tests ✅" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="• Infrastructure (PrintService): 12 tests ✅" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Funcionalidades Implementadas -->
                <StackPanel Spacing="12">
                    <TextBlock Text="⚙️ Funcionalidades Implementadas" FontSize="20" FontWeight="SemiBold"/>
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="✅ Modelos de dominio (PrintSession, TandaInfo, WorkflowStage)"/>
                            <TextBlock Text="✅ Validación de parámetros"/>
                            <TextBlock Text="✅ Cálculo de tandas (frente/dorso)"/>
                            <TextBlock Text="✅ Servicio PDF (contar, extraer, generar tandas)"/>
                            <TextBlock Text="✅ Servicio de impresión (enumerar, SumatraPDF)"/>
                            <TextBlock Text="✅ Arquitectura MVVM preparada"/>
                            <TextBlock Text="✅ Inyección de dependencias"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Próximos Pasos -->
                <StackPanel Spacing="12">
                    <TextBlock Text="🚀 Próximos Pasos" FontSize="20" FontWeight="SemiBold"/>
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="1. SessionStore - Persistencia y reanudación"/>
                            <TextBlock Text="2. ViewModels - Lógica de presentación"/>
                            <TextBlock Text="3. UI completa - Diseño documentado en docs/UI_DESIGN.md"/>
                            <TextBlock Text="4. Empaquetado MSIX"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Info -->
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="16" Opacity="0.9">
                    <StackPanel Spacing="8">
                        <TextBlock Text="ℹ️ Cómo ejecutar desde Visual Studio:" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Foreground="White" TextWrapping="Wrap">
                            1. Abre la solución en Visual Studio<LineBreak/>
                            2. Selecciona KeepPrinter.App como proyecto de inicio<LineBreak/>
                            3. Elige plataforma (x64 recomendado)<LineBreak/>
                            4. Presiona F5 o clic en "Iniciar"
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
