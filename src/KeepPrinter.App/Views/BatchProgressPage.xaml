<Page
    x:Class="KeepPrinter.App.Views.BatchProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:KeepPrinter.App.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel MaxWidth="900" Padding="40" Spacing="24">

            <!-- Encabezado -->
            <StackPanel Spacing="8">
                <TextBlock 
                    Text="Impresión por Tandas" 
                    Style="{StaticResource TitleTextBlockStyle}"
                    Foreground="#2A2A72"/>
                <TextBlock 
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="16">
                    <Run Text="Tanda "/>
                    <Run Text="{x:Bind ViewModel.CurrentBatchNumber, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" de "/>
                    <Run Text="{x:Bind ViewModel.TotalBatches, Mode=OneWay}" FontWeight="Bold"/>
                </TextBlock>
            </StackPanel>

            <!-- Selección de impresora -->
            <StackPanel Spacing="12">
                <TextBlock 
                    Text="Impresora" 
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Foreground="#2A2A72"
                    FontWeight="SemiBold"/>

                <ComboBox 
                    ItemsSource="{x:Bind ViewModel.AvailablePrinters, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedPrinter, Mode=TwoWay}"
                    PlaceholderText="Seleccione una impresora"
                    HorizontalAlignment="Stretch"
                    MinWidth="300"/>
            </StackPanel>

            <!-- Información de la tanda actual -->
            <Border 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">

                <StackPanel Spacing="16">
                    <TextBlock 
                        Text="Detalles de la Tanda" 
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Foreground="#2A2A72"/>

                    <Grid RowSpacing="12" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Páginas frente:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.CurrentBatch.FrontPages, Mode=OneWay}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Páginas dorso:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.CurrentBatch.BackPages, Mode=OneWay}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Estado frente:" FontWeight="SemiBold"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <FontIcon 
                                Glyph="{x:Bind ViewModel.CurrentBatch.FrontPrinted, Mode=OneWay}"
                                FontSize="16"
                                Foreground="{x:Bind ViewModel.CurrentBatch.FrontPrinted, Mode=OneWay}"/>
                            <TextBlock>
                                <Run Text="{x:Bind ViewModel.CurrentBatch.FrontPrinted, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Estado dorso:" FontWeight="SemiBold"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <FontIcon 
                                Glyph="{x:Bind ViewModel.CurrentBatch.BackPrinted, Mode=OneWay}"
                                FontSize="16"
                                Foreground="{x:Bind ViewModel.CurrentBatch.BackPrinted, Mode=OneWay}"/>
                            <TextBlock>
                                <Run Text="{x:Bind ViewModel.CurrentBatch.BackPrinted, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Botones de impresión -->
            <StackPanel Spacing="12">
                <TextBlock 
                    Text="Acciones de Impresión" 
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Foreground="#2A2A72"
                    FontWeight="SemiBold"/>

                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button 
                        Grid.Row="0" Grid.Column="0"
                        Content="🖨️ Imprimir Frente"
                        Command="{x:Bind ViewModel.PrintFrontCommand}"
                        IsEnabled="{x:Bind ViewModel.CanPrintFront, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Height="48"/>

                    <Button 
                        Grid.Row="0" Grid.Column="1"
                        Content="🖨️ Imprimir Dorso"
                        Command="{x:Bind ViewModel.PrintBackCommand}"
                        IsEnabled="{x:Bind ViewModel.CanPrintBack, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Height="48"/>

                    <Button 
                        Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        Content="✓ Confirmar Tanda Completa"
                        Command="{x:Bind ViewModel.ConfirmBatchCompleteCommand}"
                        IsEnabled="{x:Bind ViewModel.CanConfirm, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Height="48"/>
                </Grid>
            </StackPanel>

            <!-- Progreso general -->
            <StackPanel Spacing="8">
                <TextBlock 
                    Text="Progreso General" 
                    FontWeight="SemiBold"/>
                <ProgressBar 
                    Value="{x:Bind ViewModel.ProgressPercentage, Mode=OneWay}"
                    Maximum="100"
                    Height="8"/>
                <TextBlock 
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="12">
                    <Run Text="{x:Bind ViewModel.CompletedBatches, Mode=OneWay}"/>
                    <Run Text=" de "/>
                    <Run Text="{x:Bind ViewModel.TotalBatches, Mode=OneWay}"/>
                    <Run Text=" tandas completadas"/>
                </TextBlock>
            </StackPanel>

            <!-- Mensajes -->
            <InfoBar 
                IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToBoolConverter}}"
                Severity="Error"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                IsClosable="True"/>

            <InfoBar 
                IsOpen="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource StringToBoolConverter}}"
                Severity="Success"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                IsClosable="False"/>

            <!-- Acciones secundarias -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button 
                    Content="📁 Abrir Carpeta"
                    Command="{x:Bind ViewModel.OpenOutputFolderCommand}"/>

                <Button 
                    Content="❌ Cancelar Sesión"
                    Command="{x:Bind ViewModel.CancelSessionCommand}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
