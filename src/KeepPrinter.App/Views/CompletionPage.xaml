<Page
    x:Class="KeepPrinter.App.Views.CompletionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel 
            MaxWidth="700" 
            Padding="40" 
            Spacing="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <!-- Encabezado con icono de éxito -->
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <FontIcon 
                    Glyph="&#xE73E;" 
                    FontSize="64"
                    Foreground="#4CAF50"/>

                <TextBlock 
                    Text="¡Sesión Completada!" 
                    Style="{StaticResource TitleTextBlockStyle}"
                    Foreground="#2A2A72"
                    HorizontalAlignment="Center"/>

                <TextBlock 
                    Text="Todas las tandas han sido impresas exitosamente"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"/>
            </StackPanel>

            <!-- Tarjeta con resumen -->
            <Border 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">

                <StackPanel Spacing="20">
                    <TextBlock 
                        Text="Resumen de la Sesión" 
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Foreground="#2A2A72"
                        FontWeight="SemiBold"/>

                    <Grid RowSpacing="16" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Archivo -->
                        <FontIcon Grid.Row="0" Grid.Column="0" Glyph="&#xE8A5;" Foreground="#2A2A72"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Archivo procesado" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.SourceFileName, Mode=OneWay}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Páginas -->
                        <FontIcon Grid.Row="1" Grid.Column="0" Glyph="&#xE8A8;" Foreground="#2A2A72"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Total de páginas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock FontWeight="SemiBold">
                                <Run Text="{x:Bind ViewModel.TotalPages, Mode=OneWay}"/>
                                <Run Text=" páginas"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Tandas -->
                        <FontIcon Grid.Row="2" Grid.Column="0" Glyph="&#xE8FD;" Foreground="#2A2A72"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Tandas completadas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock FontWeight="SemiBold">
                                <Run Text="{x:Bind ViewModel.CompletedBatches, Mode=OneWay}"/>
                                <Run Text=" de "/>
                                <Run Text="{x:Bind ViewModel.TotalBatches, Mode=OneWay}"/>
                                <Run Text=" tandas"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Duración -->
                        <FontIcon Grid.Row="3" Grid.Column="0" Glyph="&#xE917;" Foreground="#2A2A72"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Duración" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.DurationFormatted, Mode=OneWay}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Carpeta -->
                        <FontIcon Grid.Row="4" Grid.Column="0" Glyph="&#xE8B7;" Foreground="#2A2A72"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Carpeta de salida" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock 
                                Text="{x:Bind ViewModel.OutputFolder, Mode=OneWay}" 
                                FontWeight="SemiBold"
                                TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Botones de acción -->
            <StackPanel Spacing="12">
                <Button 
                    Content="📁 Abrir Carpeta de Salida"
                    Command="{x:Bind ViewModel.OpenOutputFolderCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Height="48"/>

                <Button 
                    Content="🔄 Nueva Sesión"
                    Command="{x:Bind ViewModel.StartNewSessionCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Height="48"/>

                <Button 
                    Content="❌ Salir"
                    Command="{x:Bind ViewModel.ExitApplicationCommand}"
                    HorizontalAlignment="Stretch"
                    Height="40"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
